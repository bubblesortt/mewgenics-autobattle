// Applies AI presets to each base class via innate_passives.
// innate_passives is auto-applied to all cats of the class from the start.

Hunter.merge {
    innate_passives {
        ReplaceBrain {
            brain GenericBrain
            decision_weights smart_hunter
            move_weights smart_hunter_move
        }
    }
}

