// Applies AI presets to each advanced class via innate_passives.
// innate_passives is auto-applied to all cats of the class from the start.

Butcher.merge {
    innate_passives {
        ReplaceBrain {
            brain GenericBrain
            decision_weights smart_butcher
            move_weights smart_butcher_move
        }
    }
}

