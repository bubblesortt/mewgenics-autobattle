// --- 1. LETHAL CHECK FUNCTION (MELEE & POTENTIAL SUICIDE) ---
// The Butcher should only engage a boss in melee if the execution is guaranteed.
// If it survives, the Butcher will take fatal punishment.

// Mutilate (1 damage x 3 hits = threshold 3)
Mutilate.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 3 } Else { FlatAIBonus -999999 } } } Conditional_Speculative { Conditional_HasStatus { status Thorns  FlatAIBonus -50 } } Conditional_Speculative { Conditional_HasStatus { status Brace  FlatAIBonus -15 } } Conditional_Speculative { Conditional_HasStatus { status AllDamageImmune  FlatAIBonus -9999 } } Conditional_Speculative { Conditional_Enemy { Conditional_HealthThreshold { threshold_percent 25%  FlatAIBonus 40 } } } } } }
