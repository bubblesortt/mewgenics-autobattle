// --- 1. DISABLE DANGEROUS AND SUICIDAL INVENTIONS ---
// Shockwave hits EVERYONE on the map, including your own cats. Disabled.
Shockwave.merge { damage_instance { ai_base_score -99999 } }
Shockwave2.merge { damage_instance { ai_base_score -99999 } }

// These gadgets have random teleport effects or explode on the caster.
ShoddyJetpack.merge { damage_instance { ai_base_score -99999 } }
ShoddyJetpack2.merge { damage_instance { ai_base_score -99999 } }

EjectButton.merge { damage_instance { ai_base_score -99999 } }
EjectButton2.merge { damage_instance { ai_base_score -99999 } }

// FreshOffTheForge burns the Tinkerer. The shield is not worth the Burn status.
FreshOffTheForge.merge { damage_instance { ai_base_score -99999 } }
FreshOffTheForge2.merge { damage_instance { ai_base_score -99999 } }

// AutoPilot hands control to the AI... the AI should not cast this. It is redundant and costs 10 mana.
AutoPilot.merge { damage_instance { ai_base_score -99999 } }
AutoPilot2.merge { damage_instance { ai_base_score -99999 } }

// Ejecting from the Mech or exploding it kills the caster or leaves them very vulnerable and ends their turn.
MechSuitEject.merge { damage_instance { ai_base_score -99999 } }
MechExplode.merge { damage_instance { ai_base_score -99999 } }


// --- 2. LETHAL STRIKE CHECKS (OFFENSIVE TELEPORTS AND DASH) ---
// The Tinkerer should NEVER charge into a boss's face. It is too fragile.

// DrillDown teleports the caster ONTO the target. Strictly forbidden on bosses.
DrillDown.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }
DrillDown2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }

// VoltTackle (5 damage)
VoltTackle.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
VoltTackle2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }

// RocketSkates (5 damage)
RocketSkates.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
RocketSkates2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }
RocketSkates_Bombchu.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 5 } Else { FlatAIBonus -999999 } } } } } }


