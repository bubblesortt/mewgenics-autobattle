// --- 1. ABSOLUTE AGGRO PRIORITY (TAUNTING) ---
// These abilities force bosses to attack the Tank, saving the rest of the team.
// The AI should use them as soon as an enemy is in range.
Taunt.merge { damage_instance { ai_base_score 80 } }
Taunt2.merge { damage_instance { ai_base_score 80 } }

DrawAttention.merge { damage_instance { ai_base_score 75 } }
DrawAttention2.merge { damage_instance { ai_base_score 75 } }

Intimidate.merge { damage_instance { ai_base_score 70 } } // Applies Fear, excellent defensive debuff.
Intimidate2.merge { damage_instance { ai_base_score 70 } }

BodyGuard.merge { damage_instance { ai_base_score 85 } } // Lets the Tank take hits for an ally.
BodyGuard2.merge { damage_instance { ai_base_score 85 } }


// --- 2. HEAVY KNOCKBACKS AND CROWD CONTROL ---
