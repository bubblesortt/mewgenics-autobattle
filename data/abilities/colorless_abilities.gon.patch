// --- 3. LETHAL STRIKE CHECKS (MELEE ATTACKS) ---
// Colorless is fragile. If it hits a boss in melee, it must be certain to finish it.
Smack.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 2 } Else { FlatAIBonus -999999 } } } } } }
Smack2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 4 } Else { FlatAIBonus -999999 } } } } } }

// DexterousHit scales with Dexterity, too variable for simple AI prediction. Ban in boss melee.
DexterousHit.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }
DexterousHit2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }

// Knead is a melee attack that applies debuffs. The vaporization risk is too high.
Knead.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }
Knead2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { FlatAIBonus -999999 } } } } }


