// =====================================================================
// OPTIMIZED CLERIC AI PATCH - SURVIVAL, BUFFS, AND SMART HEALING
// =====================================================================

// --- 1. SAFE MELEE ATTACKS ---
// The Cleric should only hit a boss in melee if it can kill.
// "OpenWounds" scales with the target's missing HP (up to 25/50 damage).
// Strictly forbid its use on a boss unless it is the finishing blow.
OpenWounds.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 25 } Else { FlatAIBonus -999999 } } } } } }
OpenWounds2.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 50 } Else { FlatAIBonus -999999 } } } } } }


// --- 2. BAN SUPPORT SUICIDES ---
// "BornAgain" sleeps the Cleric for 4 turns. In front of a boss, the healer dies.
// The Autobattler cannot handle this level of vulnerability. Disable it.
BornAgain.merge { damage_instance { ai_base_score -99999 } }
BornAgain2.merge { damage_instance { ai_base_score -99999 } }


// --- 3. HEALING OPTIMIZATION (DO NOT WASTE MANA) ---
// Force the AI to heal only targets that really need it
// and give very high scores to prioritize team survival.
RangedHeal.merge { damage_instance { ai_base_score 70 custom_additional_ai_weight must_heal_most_missing_health } }
RangedHeal2.merge { damage_instance { ai_base_score 70 custom_additional_ai_weight must_heal_most_missing_health } }

