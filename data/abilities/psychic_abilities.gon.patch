MassManaLeech.merge { damage_instance { ai_base_score -99999 } }
MassManaLeech2.merge { damage_instance { ai_base_score -99999 } }

BlindingFlash.merge { damage_instance { ai_base_score -99999 } } // Level 1 blinds allies
BlindingFlash2.merge { damage_instance { ai_base_score 0 } } // Level 2 excludes allies, it is safe.

// Glare makes the target Mad (Madness) with no restriction. If cast on an ally...
Glare.merge { damage_instance { ai_base_score -99999 } }
Glare2.merge { damage_instance { ai_base_score -99999 } }


// --- 3. BAN TURN-SKIPPING SPELLS (SUICIDE) ---
// "Pass", "ThinkDeep", and "ExtraTurnQuestion" sleep or stun the caster.
// Against a vaporizer, losing a turn is death.
Pass.merge { damage_instance { ai_base_score -99999 } }
Pass2.merge { damage_instance { ai_base_score -99999 } }

