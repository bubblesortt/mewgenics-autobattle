// --- 1. DISABLE CHAOTIC SPELLS AND RANDOM TELEPORTS ---
// These abilities shuffle everyone's positions. If a boss is teleported
// into the team (or a fragile ally is teleported in front of the boss), it is over.
RealityScramble.merge { damage_instance { ai_base_score -99999 } }
RealityScramble2.merge { damage_instance { ai_base_score -99999 } }

ChaosSwap2.merge { damage_instance { ai_base_score -99999 } }

// Bump and Flicker teleport a target. It is too risky to let the AI decide
// where to send an ally or an enemy.
Flicker.merge { damage_instance { ai_base_score -99999 } }
Flicker2.merge { damage_instance { ai_base_score -99999 } }


// --- 2. TEAM PROTECTION (ANTI-FRIENDLY-FIRE) ---
// These AoE spells hit everyone, including allies, and apply destructive
// statuses (Madness, Blind). The native AI does not calculate the risk/benefit well.
MindCrack.merge { damage_instance { ai_base_score -99999 } }
MindCrack2.merge { damage_instance { ai_base_score -99999 } }

MindBlast.merge { damage_instance { ai_base_score -99999 } }
