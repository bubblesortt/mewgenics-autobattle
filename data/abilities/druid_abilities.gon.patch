// TIGER FORM (TigerSwipes, Pounce) - Threshold 3 for claws, 2 for pounce.
TigerSwipes.merge { damage_instance { ai_base_score 0 effects { Conditional_Speculative { Conditional_Boss { Conditional_HealthThreshold { threshold_flat 3 } Else { FlatAIBonus -999999 } } }  Conditional_Speculative { Conditional_HasStatus { status Thorns  FlatAIBonus -25 } } Conditional_Speculative { Conditional_HasStatus { status Brace  FlatAIBonus -15 } } Conditional_Speculative { Conditional_HasStatus { status AllDamageImmune  FlatAIBonus -9999 } } Conditional_Speculative { Conditional_Enemy { Conditional_HealthThreshold { threshold_percent 25%  FlatAIBonus 40 } } } } } }
