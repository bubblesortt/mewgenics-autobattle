// =====================================================================
// OPTIMIZED HUNTER AI PATCH - ANTI-VAPORIZATION
// =====================================================================

// --- 1. DISABLE SUICIDAL MANEUVERS ---
// Harpoon pulls the Hunter into melee with the target.
// Strictly forbid the AI from using Harpoon against a boss.
Harpoon.merge {
    damage_instance {
        effects {
            Conditional_Speculative {
                Conditional_Boss {
                    FlatAIBonus -999999
                }
            }
        }
    }
}
Harpoon2.merge {
    damage_instance {
        effects {
            Conditional_Speculative {
                Conditional_Boss {
                    FlatAIBonus -999999
                }
            }
        }
    }
}

// Vivisect is a melee attack (range 1).
// The AI should use it on a boss ONLY if the damage (5 by default) is enough to kill.
Vivisect.merge {
    damage_instance {
        effects {
            Conditional_Speculative {
                Conditional_Boss {
                    Conditional_HealthThreshold {
                        threshold_flat 5
                    } Else {
                        FlatAIBonus -999999
                    }
                }
            }
        }
    }
}
Vivisect2.merge {
    damage_instance {
        effects {
            Conditional_Speculative {
                Conditional_Boss {
                    Conditional_HealthThreshold {
                        threshold_flat 5
                    } Else {
                        FlatAIBonus -999999
                    }
                }
            }
        }
    }
}

// --- 2. EXTREME PRIORITY ON HARASSMENT AND TRAPS ---
// Force the AI to place traps between itself and bosses to block their advance (kiting)
BearTrap.merge { damage_instance { ai_base_score 80 } }
BearTrap2.merge { damage_instance { ai_base_score 80 } }

SpikeTrap.merge { damage_instance { ai_base_score 75 } }
SpikeTrap2.merge { damage_instance { ai_base_score 75 } }

