Bunker2.merge { damage_instance { ai_base_score 85 } }

CharmTrap.merge { damage_instance { ai_base_score 60 } }
CharmTrap2.merge { damage_instance { ai_base_score 60 } }


// --- 3. SURVIVAL MOBILITY AND REPOSITIONING ---
// Tactical retreat (teleportation) should be the top priority if the enemy closes in.
TacticalRetreat.merge { damage_instance { ai_base_score 100 } }
TacticalRetreat2.merge { damage_instance { ai_base_score 100 } }

Diversion.merge { damage_instance { ai_base_score 50 } }
Diversion2.merge { damage_instance { ai_base_score 50 } }


// --- 4. DISABLE PROBLEMATIC SKILLS ---
// Remove skills that cause friendly fire, waste turns, or force melee.
ChaosShot.merge { damage_instance { ai_base_score -99999 } }
ChaosShot2.merge { damage_instance { ai_base_score -99999 } }

Pheromones.merge { damage_instance { ai_base_score -99999 } }
Pheromones2.merge { damage_instance { ai_base_score -99999 } }

// Extend increases melee range, which pushes the AI into contact. Ban it.
Extend.merge { damage_instance { ai_base_score -99999 } }
Extend2.merge { damage_instance { ai_base_score -99999 } }

// StakeOut skips a unit's turn. In front of a vaporizer, that is death.
StakeOut.merge { damage_instance { ai_base_score -99999 } }
StakeOut2.merge { damage_instance { ai_base_score -99999 } }


