// --- RANGED KITING SPECIALISTS ---
// Goal: Keep the target at the absolute edge of range to outrun 3-move enemies (e.g., Carnibulb).

smart_hunter_move.merge {
    distance_to_enemy 2
    distance_to_ally 0
    distance_to_character 0
    // Use mov+reach (inspired by keep_max_ranged_distance) to back up while shooting
    preferred_distance mov+reach
    total_distance_moved 0.01
    face_closest_enemy 1
    danger_avoidance 10
    // Raised to 5 (inspired by prefer_tall_grass_always_move [cite: 6]) to maximize evasion
    tall_grass 5
}

smart_mage_move.merge {
